{
  "firestore": {
    "database": "sunti",
    "location": "asia-southeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": [
    {
      "target": "cabinet",
      "public": ".",
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
          ]
        }
      ],
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "portal.html",
        "portal_test.html"
      ]
    },
    {
      "target": "customer",
      "public": ".",
      "headers": [
        {
          "source": "**",
          "headers": [
            { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
          ]
        }
      ],
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "functions/**",
        "index.html",
        "contracts.html",
        "contractors.html",
        "invoices.html",
        "finance.html",
        "statements.html",
        "reconciliation.html",
        "reports.html",
        "folders.html",
        "companies.html",
        "users.html",
        "categories.html",
        "telegram.html",
        "portal_settings.html",
        "documentation.html",
        "materials.html",
        "ctc.html",
        "whatsapp.html",
        "ai.html",
        "ai_chat.html",
        "404.html",
        "HELPS/**",
        "CLAUDE/**",
        "_auth.js",
        "_header.js",
        "_firebase.js"
      ],
      "rewrites": [
        {
          "source": "/test",
          "destination": "/portal_test.html"
        },
        {
          "source": "**",
          "destination": "/portal.html"
        }
      ]
    }
  ]
}
